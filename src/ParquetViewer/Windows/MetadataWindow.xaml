<controls:WindowBase
    x:Class="ParquetViewer.Windows.MetadataWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ParquetViewer.Controls;assembly=ParquetViewer.Support"
    Title="Metadata Viewer"
    Width="860"
    Height="620"
    MinWidth="480"
    MinHeight="300"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Loading  -->
        <Grid x:Name="LoadingPanel" Grid.Row="0">
            <ProgressBar
                Width="200"
                Height="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsIndeterminate="True" />
        </Grid>

        <!--  Tabs (hidden until loaded)  -->
        <TabControl
            x:Name="MetadataTabControl"
            Grid.Row="0"
            Visibility="Collapsed" />

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="1"
            Margin="8,6"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="CopyButton"
                Margin="0,0,8,0"
                Padding="10,4"
                Click="CopyButton_Click"
                Content="Copy to Clipboard" />
            <Button
                Padding="10,4"
                Click="CloseButton_Click"
                Content="Close" />
        </StackPanel>
    </Grid>
</controls:WindowBase>
