<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ParquetViewer.Form.UI.Views"
    xmlns:vm="clr-namespace:ParquetViewer.Form.Local.ViewModels">

    <Style TargetType="{x:Type views:FieldSelectionContent}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:FieldSelectionContent}">
                    <DockPanel Background="{DynamicResource WindowBackgroundBrush}" LastChildFill="True">

                        <!--  Filter row  -->
                        <Grid Margin="8,8,8,4" DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Margin="0,0,4,0"
                                VerticalContentAlignment="Center"
                                Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                Padding="8,3"
                                Command="{Binding ClearFilterCommand}"
                                Content="Clear" />
                        </Grid>

                        <!--  Load mode radio buttons  -->
                        <StackPanel
                            Margin="8,0,8,4"
                            DockPanel.Dock="Top"
                            Orientation="Vertical">
                            <RadioButton
                                Margin="0,2"
                                Content="Load all fields"
                                Foreground="{DynamicResource ForegroundBrush}"
                                IsChecked="{Binding LoadAllFields}" />
                            <RadioButton
                                Margin="0,2"
                                Content="{Binding SelectedFieldCountText}"
                                Foreground="{DynamicResource ForegroundBrush}"
                                IsChecked="{Binding LoadSelectedFields}" />
                        </StackPanel>

                        <!--  Select All checkbox  -->
                        <CheckBox
                            Margin="8,0,8,4"
                            Content="{Binding SelectAllCheckboxText}"
                            DockPanel.Dock="Top"
                            Foreground="{DynamicResource ForegroundBrush}"
                            IsChecked="{Binding SelectAll}"
                            IsEnabled="{Binding LoadSelectedFields}" />

                        <!--  Bottom buttons  -->
                        <Grid Margin="8,4,8,8" DockPanel.Dock="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Content="Always load all fields"
                                Foreground="{DynamicResource ForegroundBrush}"
                                IsChecked="{Binding RememberChoice}"
                                IsEnabled="{Binding LoadAllFields}" />
                            <Button
                                Grid.Column="1"
                                MinWidth="75"
                                Padding="8,3"
                                Command="{Binding ConfirmCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Content="Done" />
                            <Button
                                Grid.Column="3"
                                MinWidth="75"
                                Padding="8,3"
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Content="Cancel" />
                        </Grid>

                        <!--  Field list  -->
                        <Border
                            Margin="8,0,8,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                            <ListBox
                                Background="{DynamicResource GridBackgroundBrush}"
                                BorderThickness="0"
                                Foreground="{DynamicResource ForegroundBrush}"
                                IsEnabled="{Binding LoadSelectedFields}"
                                ItemsSource="{Binding DisplayFields}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="2,1" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FieldItem}">
                                        <CheckBox
                                            Padding="4,2"
                                            Content="{Binding Name}"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            IsChecked="{Binding IsSelected}"
                                            IsEnabled="{Binding IsEnabled}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
