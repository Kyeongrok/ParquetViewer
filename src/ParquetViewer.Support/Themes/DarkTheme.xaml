<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Background colors  -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#2C2C2C" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#0D1117" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#2C2C2C" />
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#2C2C2C" />

    <!--  Foreground colors  -->
    <SolidColorBrush x:Key="ForegroundBrush" Color="#F0F6FC" />
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#888888" />
    <SolidColorBrush x:Key="PlaceholderForegroundBrush" Color="#919BA4" />

    <!--  DataGrid colors  -->
    <SolidColorBrush x:Key="GridBackgroundBrush" Color="#212121" />
    <SolidColorBrush x:Key="GridCellBackgroundBrush" Color="#0D1117" />
    <SolidColorBrush x:Key="GridAlternateRowBrush" Color="#151B23" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#1E2226" />
    <SolidColorBrush x:Key="GridHeaderForegroundBrush" Color="#F0F6FC" />
    <SolidColorBrush x:Key="GridBorderBrush" Color="#3D444D" />
    <SolidColorBrush x:Key="GridSelectionBackgroundBrush" Color="#40813D" />
    <SolidColorBrush x:Key="GridSelectionForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FrozenColumnHeaderBrush" Color="#212539" />
    <SolidColorBrush x:Key="FrozenCellBackgroundBrush" Color="#282C30" />

    <!--  Link / accent colors  -->
    <SolidColorBrush x:Key="HyperlinkBrush" Color="#4493F8" />
    <SolidColorBrush x:Key="ActiveHyperlinkBrush" Color="#D3D3D3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4493F8" />

    <!--  Border / separator  -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#3D444D" />
    <SolidColorBrush x:Key="BorderBrush" Color="#3D444D" />

    <!--  Status bar  -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#1C1C1C" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#F0F6FC" />

</ResourceDictionary>
