<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Background colors  -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#F0F0F0" />

    <!--  Foreground colors  -->
    <SolidColorBrush x:Key="ForegroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#808080" />
    <SolidColorBrush x:Key="PlaceholderForegroundBrush" Color="#999999" />

    <!--  DataGrid colors  -->
    <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="GridCellBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="GridAlternateRowBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="GridHeaderForegroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="GridBorderBrush" Color="#AAAAAA" />
    <SolidColorBrush x:Key="GridSelectionBackgroundBrush" Color="#0078D7" />
    <SolidColorBrush x:Key="GridSelectionForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FrozenColumnHeaderBrush" Color="#D0D8E4" />
    <SolidColorBrush x:Key="FrozenCellBackgroundBrush" Color="#E8ECF0" />

    <!--  Link / accent colors  -->
    <SolidColorBrush x:Key="HyperlinkBrush" Color="#000080" />
    <SolidColorBrush x:Key="ActiveHyperlinkBrush" Color="#FF0000" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D7" />

    <!--  Border / separator  -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC" />
    <SolidColorBrush x:Key="BorderBrush" Color="#AAAAAA" />

    <!--  Status bar  -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#007ACC" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#FFFFFF" />

</ResourceDictionary>
